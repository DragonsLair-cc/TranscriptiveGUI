<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LinuxGUI.Views.HomeView">
    
    <StackPanel Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Home" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,35"/>
        <TextBlock Text="Welcome to Transcriptive!" FontSize="18" FontWeight="" HorizontalAlignment="Center"/>
        <TextBlock Text="We're an AI provider, designed to help medical personnel" FontSize="18" FontWeight="" HorizontalAlignment="Center"/>
        <TextBlock Text="quickly summarize patient history so that Doctors can" FontSize="18" FontWeight="" HorizontalAlignment="Center"/>
        <TextBlock Text="spend less time reading - and patients can spend" FontSize="18" FontWeight="" HorizontalAlignment="Center"/>        
        <TextBlock Text="less time worrying." FontSize="18" FontWeight="" HorizontalAlignment="Center"/>
        
    </StackPanel>
    
</UserControl>
