<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LinuxGUI.Views.HomeView">
    
    <DockPanel>
        <Panel DockPanel.Dock="Left" Width="200" Margin="5,5,5,5">
            <Rectangle Fill="#1d1d1d" RadiusX="5" RadiusY="5"/>
            
            <Grid RowDefinitions="Auto, *">
                <StackPanel Grid.Row="0" Spacing="10" Margin="10">
                    <TextBlock Text="Menu"
                               FontSize="20"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="10"/>
                
                    <Button Content="Home"
                            Width="125"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Background="AntiqueWhite"
                            Foreground="Black"
                            />
                    <Button Content="Transcribe"
                            Width="125"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Background="AntiqueWhite"
                            Foreground="Black"
                    />
                    <Button Content="Upload"
                            Width="125"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Background="AntiqueWhite"
                            Foreground="Black"
                    />
                </StackPanel>
                
                <Button Grid.Row="1" Content="Settings"
                        Width="125"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Background="AntiqueWhite"
                        Foreground="Black"
                        Margin="0,175,0,0"
                />
                
            </Grid>
            
        </Panel>    
            <TextBlock Text="Avalon Main"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
    </DockPanel>
    
</UserControl>
